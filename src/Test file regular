// ── Prompt italiano ───────────────────────────────────────────────────────
const buildPrompt = (name, day, month, daysUntil, age, birthYear) => {
  const mese = ['gennaio','febbraio','marzo','aprile','maggio','giugno',
    'luglio','agosto','settembre','ottobre','novembre','dicembre'][month - 1];
  let timing = '';
  if (daysUntil === 0)               timing = 'OGGI e il compleanno!';
  else if (daysUntil > 0 && daysUntil <= 7)  timing = `Tra ${daysUntil} giorno${daysUntil===1?'':'i'} e il compleanno.`;
  else if (daysUntil < 0 && daysUntil >= -7) timing = `Il compleanno era ${Math.abs(daysUntil)} giorno${Math.abs(daysUntil)===1?'':'i'} fa.`;

  let tono = '';
  let fatti_hint = '';

  if (age !== null && age <= 10) {
    tono = 'Parla in modo molto allegro, magico e adatto a bambini piccoli.';
    fatti_hint = 'Scegli curiosita divertenti adatte ai bambini: animali, giocattoli, cartoni animati, parchi divertimento.';
  } else if (age !== null && age <= 17) {
    tono = 'Parla in modo fresco, energico e adatto ai ragazzi.';
    fatti_hint = 'Scegli curiosita interessanti per ragazzi: sport, musica, cinema, tecnologia.';
  } else if (age !== null && age >= 80) {
    tono = 'Parla con grande calore, rispetto e ammirazione per una vita lunga e ricca. Menziona brevemente un ricordo musicale degli anni della sua giovinezza.';
    fatti_hint = `Scegli curiosita storiche del ${day} ${mese} legate agli anni della giovinezza di questa persona (musica, cinema, moda, storia italiana degli anni in cui aveva 15-25 anni).`;
  } else if (age !== null && age >= 60) {
    tono = 'Parla con calore e nostalgia affettuosa.';
    fatti_hint = `Scegli curiosita storiche del ${day} ${mese} interessanti per adulti, preferibilmente degli anni della loro giovinezza.`;
  } else {
    tono = 'Parla in modo caloroso, gioioso e rispettoso.';
    fatti_hint = `Scegli curiosita storiche reali del ${day} ${mese} interessanti per un adulto.`;
  }

  const etaStr = age !== null ? `Eta: ${age} anni.` : '';
  const annoStr = birthYear ? `Anno di nascita: ${birthYear}.` : '';

  return `Sei lo Specchio Magico degli Auguri di una foresta incantata. ${tono} Usa solo l'italiano.

Persona: ${name} | Compleanno: ${day} ${mese} | ${timing} ${etaStr} ${annoStr}

${fatti_hint}

Dai un messaggio di auguri personale (max 3 frasi) e precisamente 2 o 3 curiosita storiche reali del ${day} ${mese}.

Rispondi SOLO come JSON senza markdown:
{"it":"...","fatti":[{"anno":1984,"it":"..."}]}`;
};

